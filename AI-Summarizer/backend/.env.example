# ──────────────────────────────────────────────────────────
# AI Text Summarizer — Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────



# --- SMTP Email (OTP Verification) ---
# Gmail: enable 2-Step Verification, then create App Password at:
# https://myaccount.google.com/apppasswords
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_NAME=AI Summarizer

# --- GROQ API Key (optional: fast local summarizer responses) ---
# Get from your GROQ provider dashboard
GROQ_API_KEY=your_groq_api_key_here

# --- HuggingFace Token (fixes BART download / 503 error) ---
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# --- LLM API Keys (Required for Phase 4+ multilingual & RAG) ---
# Get Gemini API key (FREE): https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Get OpenAI key (paid): https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# RapidAPI Key (optional: for fallback YouTube transcript downloading)
RAPIDAPI_KEY=your_rapidapi_key_here

# --- Model Configuration ---
# Options: facebook/bart-large-cnn | t5-base | t5-small | google/pegasus-xsum
DEFAULT_MODEL=facebook/bart-large-cnn

# --- App Settings ---
MAX_FILE_SIZE_MB=50
MAX_TEXT_LENGTH=100000
AUDIO_OUTPUT_DIR=audio
UPLOAD_DIR=uploads
CHROMA_DB_DIR=chroma_db
DATABASE_URL=sqlite:///./summarizer.db
